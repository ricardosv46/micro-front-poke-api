# URLs públicas de los remoteEntry.js de cada microfrontend en producción.
# En local no se necesitan: vite.config.ts cae a http://localhost:3001 / :3002 por defecto.
VITE_MF_DETAIL_URL=https://tu-sitio-detail.netlify.app/remoteEntry.js
VITE_MF_HISTORY_URL=https://tu-sitio-history.netlify.app/remoteEntry.js

# Base URL de PokeAPI. Es la misma en todos los entornos (API pública de terceros),
# se parametriza solo para no hardcodear la URL y poder apuntar a un mock en tests.
VITE_POKEAPI_BASE_URL=https://pokeapi.co/api/v2
